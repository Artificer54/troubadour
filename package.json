{
  "name": "troubadour",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "concurrently --kill-others-on-fail -n servers,tauri \"npm run dev\" \"wait-on http://localhost:5173 http://localhost:3001/api/playlists && tauri dev\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "howler": "^2.2.4",
    "lucide-react": "^0.441.0",
    "multer": "^2.2.0",
    "music-metadata": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "wait-on": "^9.0.10"
  }
}
