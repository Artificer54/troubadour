{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Troubadour",
  "version": "0.1.0",
  "identifier": "com.troubadour.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Troubadour",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/favicon.png"
    ],
    "resources": {
      "../server": "server"
    }
  }
}
